<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ackermann_car">

  <!-- Physical constants -->
  <xacro:property name="wheelbase" value="1.5"/>      <!-- m -->
  <xacro:property name="track_width" value="0.8"/>    <!-- m -->
  <xacro:property name="wheel_radius" value="0.15"/>  <!-- m -->
  <xacro:property name="wheel_width" value="0.08"/>   <!-- m -->
  <xacro:property name="body_length" value="1.8"/>    <!-- m -->
  <xacro:property name="body_width" value="0.9"/>     <!-- m -->
  <xacro:property name="body_height" value="0.4"/>    <!-- m -->
  <xacro:property name="mass" value="15.0"/>          <!-- kg -->

  <!-- Colours -->
  <material name="body_color"><color rgba="0.2 0.5 0.8 1"/></material>
  <material name="wheel_color"><color rgba="0.1 0.1 0.1 1"/></material>

  <!-- Base link (chassis) -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${mass/12*(body_width*body_width+body_height*body_height)}"
               iyy="${mass/12*(body_length*body_length+body_height*body_height)}"
               izz="${mass/12*(body_length*body_length+body_width*body_width)}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
      <material name="body_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry><box size="${body_length} ${body_width} ${body_height}"/></geometry>
    </collision>
  </link>

  <!-- ros2_control hardware interface -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <!-- Front steering joints (position controlled) -->
    <joint name="front_left_steering_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_steering_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Rear traction joints (velocity controlled) -->
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <!-- Front wheel joints (passive, state only) -->
    <joint name="front_left_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="front_right_wheel_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- Gazebo ros2_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>$(find planner_gazebo_demo)/config/ackermann_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ====================== SENSORS ============================== -->
  <!-- Lidar mount link -->
  <link name="lidar_link">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.3 0 0.35" rpy="0 0 0"/>
  </joint>

  <!-- Gazebo GPU lidar plugin (2D planar scan for SLAM) -->
  <gazebo reference="lidar_link">
    <sensor name="lidar_sensor" type="gpu_ray">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.2</min>
          <max>30.0</max>
          <resolution>0.02</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="lidar_controller" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=/scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <!-- IMU sensor for odometry improvement -->
  <gazebo reference="base_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>50</update_rate>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"/><mean>0.0</mean><stddev>2e-4</stddev><bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></x>
          <y><noise type="gaussian"/><mean>0.0</mean><stddev>2e-4</stddev><bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></y>
          <z><noise type="gaussian"/><mean>0.0</mean><stddev>2e-4</stddev><bias_mean>0.0000075</bias_mean><bias_stddev>0.0000008</bias_stddev></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"/><mean>0.0</mean><stddev>1.7e-2</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></x>
          <y><noise type="gaussian"/><mean>0.0</mean><stddev>1.7e-2</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></y>
          <z><noise type="gaussian"/><mean>0.0</mean><stddev>1.7e-2</stddev><bias_mean>0.1</bias_mean><bias_stddev>0.001</bias_stddev></z>
        </linear_acceleration>
      </imu>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu</remapping>
        </ros>
        <frame_name>base_link</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ====================== WHEELS ============================== -->
  <!-- Macro for a wheel link -->
  <xacro:macro name="wheel" params="name prefix parent x y z">
    <joint name="${name}_steering_joint" type="revolute">
      <parent link="${parent}"/>
      <child link="${name}_steering_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="${-0.6109}" upper="${0.6109}" effort="50" velocity="10"/>
    </joint>
    <link name="${name}_steering_link">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${name}_steering_link"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="0 0 0" rpy="1.570796 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
    <link name="${name}_wheel_link">
      <inertial>
        <mass value="0.8"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_color"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Rear wheels (fixed steering, just rolling) -->
  <xacro:macro name="rear_wheel" params="name prefix parent x y z">
    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}_wheel_link"/>
      <origin xyz="${x} ${y} ${z}" rpy="1.570796 0 0"/>
      <axis xyz="0 0 1"/>
    </joint>
    <link name="${name}_wheel_link">
      <inertial>
        <mass value="0.8"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.002" iyy="0.002" izz="0.002" ixy="0" ixz="0" iyz="0"/>
      </inertial>
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <material name="wheel_color"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Front-left wheel -->
  <xacro:wheel name="front_left"  prefix="fl" parent="base_link"
               x="${wheelbase/2}"  y="${track_width/2}"  z="${-0.1}"/>
  <!-- Front-right wheel -->
  <xacro:wheel name="front_right" prefix="fr" parent="base_link"
               x="${wheelbase/2}"  y="${-track_width/2}" z="${-0.1}"/>

  <!-- Rear-left wheel -->
  <xacro:rear_wheel name="rear_left"  prefix="rl" parent="base_link"
                    x="${-wheelbase/2}" y="${track_width/2}"  z="${-0.1}"/>
  <!-- Rear-right wheel -->
  <xacro:rear_wheel name="rear_right" prefix="rr" parent="base_link"
                    x="${-wheelbase/2}" y="${-track_width/2}" z="${-0.1}"/>

</robot>
